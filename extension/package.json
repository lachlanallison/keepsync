{
  "name": "keepsync-extension",
  "version": "1.0.0",
  "description": "Cross-browser tab sync extension (release packaging only; local dev does not need npm)",
  "private": true,
  "scripts": {
    "build": "webpack --mode=production --env target=chrome",
    "build:chrome": "webpack --mode=production --env target=chrome",
    "build:firefox": "webpack --mode=production --env target=firefox",
    "test": "jest"
  },
  "devDependencies": {
    "addons-linter": "^10.4.0",
    "copy-webpack-plugin": "^11.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^7.0.2"
  },
  "keywords": [
    "browser-extension",

# KeepSync Server Configuration
# Copy this file to .env and customize for your deployment

# Domain Configuration
DOMAIN=keepsync.yourdomain.com

# Server Configuration
#
# Default port is 8787 to avoid clashing with the many services that bind :8080.
# Override here if you want a different port (e.g. :8080, :3000, 127.0.0.1:8787).
SERVER_ADDRESS=:8787
DATABASE_URL=/app/data/keepsync.db

# Security Configuration (IMPORTANT: Change in production)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# Quota Configuration (MB)
QUOTA_LIMIT_MB=100

# Token Configuration
TOKEN_TTL=720h  # 30 days

# SMTP Configuration (for magic-link emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# CORS Configuration
ALLOWED_ORIGINS=https://keepsync.yourdomain.com,https://yourdomain.com

# Development Configuration
# Uncomment for development (use HTTP)
# DOMAIN=localhost:8787
# ALLOWED_ORIGINS=*

# First-boot bootstrap
#
# When the database is empty, the server auto-generates an invite token at
# startup and prints it in the log banner. It's attached to this email and
# valid for 24 h — paste it into the extension's "Invite token" field to
# activate the very first device. Leave default or set to your admin email.
# After the first device pairs, additional devices use in-app pairing codes.
BOOTSTRAP_EMAIL=admin@localhost

# Database Configuration (Advanced)
# For PostgreSQL instead of SQLite:
# DATABASE_URL=postgres://user:password@localhost/keepsync?sslmode=disable

# Monitoring Configuration
# PROMETHEUS_METRICS=true
# LOG_LEVEL=info

# Rate Limiting Configuration
# Per-device request cap for authenticated endpoints. Set to 0 to disable.
RATE_LIMIT_PER_MINUTE=120

# Request size limits (in bytes). Uploads larger than this receive HTTP 413.
# Default 2 MiB leaves headroom for 100-tab snapshots plus favicons/URLs.
MAX_BODY_BYTES=2097152

# Development mode — returns device tokens directly from /auth/magic-link
# without email delivery. Leave commented for production.
# DEV_MODE=true
